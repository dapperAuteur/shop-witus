# Copy to .env.local and fill from the operator tasks in plans/user-tasks/.
# NEVER commit .env.local. Claude does not read .env* files.

# === Database: Neon Postgres (operator task 01) ===
DATABASE_URL="postgres://USER:PASSWORD@HOST/DB?sslmode=require"

# === App ===
APP_URL="http://localhost:3030"

# === Auth: better-auth (operator task 05) ===
# Generate a long random string, e.g. `openssl rand -base64 48`
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3030"

# === Email: Mailgun magic-link (operator tasks 04, 05) ===
MAILGUN_API_KEY=""
MAILGUN_DOMAIN="mg.witus.online"
MAIL_FROM="Shop.WitUS <no-reply@mg.witus.online>"

# === Cloudinary: product images (operator tasks 03, 05) ===
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# === Store-connector token encryption (operator task 05) ===
# 32-byte key (base64/hex) used to encrypt OAuth tokens at rest in store_connections.
STORE_TOKEN_ENC_KEY=""

# === Wix connector OAuth (operator task 07) ===
WIX_CLIENT_ID=""
WIX_CLIENT_SECRET=""
WIX_REDIRECT_URI="http://localhost:3030/api/connect/wix/callback"

# === WitUS ecosystem (all optional; features no-op until set) ===
# Inbox (signed-webhook triage). source slug must match an INGEST_SOURCES entry.
INBOX_INGEST_URL=""
INBOX_SOURCE_SLUG="shop-witus"
INBOX_INGEST_SECRET=""
# Outbox (social-post drafts). Needs a shop-witus caption recipe before wiring.
OUTBOX_INGEST_URL=""
OUTBOX_SOURCE_SLUG="shop-witus"
OUTBOX_INGEST_SECRET=""
# PostHog (privacy-first; off by default even when set)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
